{
  "manifest_version": 3,
  "name": "WA-Focus — WhatsApp Sidebar Toggle",
  "version": "1.0.0",
  "description": "Toggle sidebar visibility and blur sidebar content on WhatsApp Web for distraction-free, full-width messaging.",
  "permissions": ["storage", "activeTab"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://web.whatsapp.com/*"],
      "js": ["storage.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["*://web.whatsapp.com/*"]
    }
  ]
}
