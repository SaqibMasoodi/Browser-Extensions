{
  "manifest_version": 3,
  "name": "Full-Page Screenshot",
  "version": "1.0",
  "description": "Capture a full-page screenshot of any website, download as PNG, and copy to clipboard.",
  "permissions": [
    "tabs",
    "activeTab",
    "downloads",
    "clipboardWrite",
    "scripting",
    "offscreen"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    },
    "default_title": "Take Screenshot",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      }
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
